# Lock the session directly after 10 seconds
timeout 600 'swaylock'

# Turn off displays (ALL ON ONE LINE)
timeout 720 'if [ -n "$NIRI_SOCKET" ]; then niri msg action power-off-monitors; else wlopm --off "*"; fi' resume 'if [ -n "$NIRI_SOCKET" ]; then niri msg action power-on-monitors; else wlopm --on "*"; fi'

# Lock before sleep
before-sleep 'swaylock'
