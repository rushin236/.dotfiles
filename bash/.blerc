# --- 1. Master Clipboard Sync Widget ---
function ble/widget/yank-to-system-clipboard {
  local text="${_ble_edit_kill_ring[0]:-${_ble_edit_reg_yank}}"
  [[ -z "$text" ]] && return

  # 1. Native Host Clipboard (Wayland / X11) FIRST
  if [[ "$XDG_SESSION_TYPE" == "wayland" ]] && command -v wl-copy >/dev/null 2>&1; then
    printf '%s' "$text" | wl-copy
    # ble/widget/print -s "Copied to host via Wayland"
    return 0
  elif command -v xclip >/dev/null 2>&1; then
    printf '%s' "$text" | xclip -selection clipboard
    # ble/widget/print -s "Copied to host via X11"
    return 0
  fi

  # 2. Fallback to Network/Terminal Clipboard (OSC 52)
  local b64_text
  b64_text=$(printf '%s' "$text" | base64 | tr -d '\n')
  
  if [[ -n "$TMUX" ]]; then
    printf "\ePtmux;\e\e]52;c;%s\a\e\\" "$b64_text" > /dev/tty
  else
    printf "\e]52;c;%s\a" "$b64_text" > /dev/tty
  fi
  
  # ble/widget/print -s "Copied to terminal via OSC 52"
}

# --- Visual Mode Wrapper ---
# function ble/widget/yank-visual-to-system-clipboard {
#   # 1. Execute standard visual yank (copies selection to kill ring)
#   ble/widget/vi-command/yank
#   # 2. Fire our clipboard sync logic
#   ble/widget/yank-to-system-clipboard
# }

# --- Normal Mode ---
# Yank normally (e.g., yy, yiw), then press Space followed by y to push to the system clipboard
ble-bind -m vi_nmap -f 'SP y' yank-to-system-clipboard

# --- Visual Mode ---
# Pressing Space followed by y will simulate pressing 'y' (standard yank), 
# dropping you to Normal mode, and then automatically typing ' y' to trigger the sync script.
ble-bind -m vi_xmap -s 'SP y' 'y y'

# --- 2. The ble.sh Screen Wrapper ---
ble/widget/my_conda_toggle() {
    ble/term/leave-for-widget
    conda_toggle_env
    ble/term/enter-for-widget
    ble/prompt/clear
    ble/prompt/update
    ble/textarea#redraw
}

# Conda toggle
ble-bind -m vi_imap -f 'M-t' my_conda_toggle
ble-bind -m vi_nmap -f 'M-t' my_conda_toggle
